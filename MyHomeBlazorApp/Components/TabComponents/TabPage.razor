@using BlazorBootstrap
@using MyHomeBlazorApp.Pages
@inject BlazorData.DataService DataService;
@implements IDisposable

@if (Parent.ActivePage == this)
{
    @ChildContent
}



@code {
    [CascadingParameter]
    private TabControl Parent { get; set; } = default!;

    [Parameter]
    public RenderFragment ChildContent { get; set; }

    [Parameter]
    public string Text { get; set; }

    public bool ListHasBeenChanged { get; set; } = false;
    // private List<DeviceProfile>? _test { get; set; } = new();
    public Details details { get; set; } = default!;
    

    public List<TabPage> Pages { get; set; } = new List<TabPage>();

    public TabPage? ActivePage { get; set; }

    public void AddPage(TabPage page)
    {
        if (!Pages.Contains(page))
        {
            Pages.Add(page);

            // If this is the first page added, make it active
            if (ActivePage == null)
            {
                ActivePage = page;
            }
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        // This runs automatically when the @if condition in the parent
        // removes this component from the UI.
        Parent.RemovePage(this);
        
    }    

    protected override void OnInitialized()
    {

        // _test = DataService.GetUserWithUnassignedDevicesList().Result.ToList();
        if (Parent == null)
            throw new ArgumentNullException(nameof(Parent), "TabPage must exist within a TabControl");
        Parent.AddPage(this);
        base.OnInitialized();

    }
}
